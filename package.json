{
  "name": "cliclaw",
  "version": "1.0.3",
  "description": "Telegram bot bridging AI CLIs (Claude Code, Codex) to Forum Topics",
  "main": "index.ts",
  "scripts": {
    "start": "tsx index.ts",
    "dev": "tsx watch index.ts",
    "setup": "node bin/cli.js setup"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "grammy": "^1.31.3",
    "openai": "^4.97.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/luizfeer/cliclaw.git"
  },
  "keywords": [
    "telegram",
    "claude",
    "codex",
    "cli",
    "bot",
    "forum"
  ],
  "license": "MIT",
  "bin": {
    "cliclaw": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "index.ts",
    "ecosystem.config.js",
    ".env.example",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=18"
  }
}
